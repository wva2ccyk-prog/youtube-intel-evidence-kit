{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/youtube-intel/topic_collection.schema.json",
  "title": "TopicCollection",
  "type": "object",
  "required": [
    "schema_version",
    "topic",
    "source_videos",
    "analysis_layer",
    "claim_groups",
    "terrain",
    "claim_index",
    "evidence_index",
    "grouping_method",
    "provenance",
    "limitations"
  ],
  "properties": {
    "schema_version": {"const": "youtube_topic_collection_v0.1"},
    "topic": {
      "type": "object",
      "required": ["topic_id", "title", "final_objective"],
      "properties": {
        "topic_id": {"type": "string"},
        "title": {"type": "string"},
        "final_objective": {"type": "string"}
      },
      "additionalProperties": true
    },
    "source_videos": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["video_id", "title", "role_in_topic", "transcript_source", "transcript_quality"],
        "properties": {
          "video_id": {"type": "string"},
          "title": {"type": ["string", "null"]},
          "role_in_topic": {"type": "string"},
          "transcript_source": {"type": "string"},
          "transcript_quality": {"type": "string"}
        },
        "additionalProperties": true
      }
    },
    "analysis_layer": {"const": "cross_video_topic_collection"},
    "video_record_count": {"type": "integer"},
    "claim_total": {"type": "integer"},
    "claim_groups": {
      "type": "array",
      "items": {"$ref": "#/$defs/claimGroup"}
    },
    "stance_groups": {"type": "object"},
    "terrain": {
      "type": "object",
      "required": ["repeated_claim_group_ids", "disagreement_group_ids", "outlier_group_ids", "disagreement_relations", "outlier_details", "operator_judgment_required", "truth_status", "fact_check_status"],
      "properties": {
        "repeated_claim_group_ids": {"type": "array", "items": {"type": "string"}},
        "disagreement_group_ids": {"type": "array", "items": {"type": "string"}},
        "outlier_group_ids": {"type": "array", "items": {"type": "string"}},
        "disagreement_relations": {"type": "array", "items": {"$ref": "#/$defs/disagreementRelation"}},
        "outlier_details": {"type": "array", "items": {"$ref": "#/$defs/outlierDetail"}},
        "operator_judgment_required": {"type": "boolean"},
        "truth_status": {"const": "not_evaluated"},
        "fact_check_status": {"const": "not_performed"}
      },
      "additionalProperties": true
    },
    "claim_index": {"type": "object", "additionalProperties": {"$ref": "#/$defs/claimIndexRecord"}},
    "evidence_index": {"type": "object", "additionalProperties": {"$ref": "#/$defs/evidenceIndexRecord"}},
    "grouping_method": {
      "type": "object",
      "required": ["name", "version", "intended_scope", "requires_upgrade_for_real_topics"],
      "properties": {
        "name": {"type": "string"},
        "version": {"type": "string"},
        "intended_scope": {"type": "string"},
        "requires_upgrade_for_real_topics": {"type": "boolean"},
        "upgrade_path": {"type": "array", "items": {"type": "string"}}
      },
      "additionalProperties": true
    },
    "provenance": {"type": "object"},
    "limitations": {"type": "array", "items": {"type": "string"}}
  },
  "$defs": {
    "claimGroup": {
      "type": "object",
      "required": [
        "group_id",
        "claim_group_key",
        "label",
        "video_ids",
        "claim_count",
        "stances",
        "status",
        "claim_uids",
        "member_claim_uids",
        "representative_claim_uid",
        "evidence_ids",
        "evidence_coordinates",
        "source_diversity",
        "grouping_method",
        "grouping_confidence",
        "why_grouped",
        "human_review_required"
      ],
      "properties": {
        "group_id": {"type": "string"},
        "claim_group_key": {"type": "string"},
        "label": {"type": "string"},
        "summary": {"type": "string"},
        "video_ids": {"type": "array", "items": {"type": "string"}},
        "claim_count": {"type": "integer"},
        "stances": {"type": "array", "items": {"type": "string"}},
        "support_roles": {"type": "array", "items": {"type": "string"}},
        "status": {
          "type": "object",
          "required": ["repeated_claim", "disagreement_point", "outlier_claim"],
          "properties": {
            "repeated_claim": {"type": "boolean"},
            "disagreement_point": {"type": "boolean"},
            "outlier_claim": {"type": "boolean"}
          },
          "additionalProperties": false
        },
        "claim_uids": {"type": "array", "items": {"type": "string"}},
        "member_claim_uids": {"type": "array", "items": {"type": "string"}},
        "representative_claim_uid": {"type": ["string", "null"]},
        "evidence_ids": {"type": "array", "items": {"type": "string"}},
        "evidence_coordinates": {"type": "array", "items": {"type": "string"}},
        "source_diversity": {
          "type": "object",
          "required": ["video_count", "speaker_count", "channel_count"],
          "properties": {
            "video_count": {"type": "integer"},
            "speaker_count": {"type": "integer"},
            "channel_count": {"type": "integer"}
          },
          "additionalProperties": true
        },
        "grouping_method": {"type": "string"},
        "grouping_confidence": {"enum": ["high", "medium", "low"]},
        "why_grouped": {"type": "array", "items": {"type": "string"}},
        "human_review_required": {"type": "boolean"},
        "outlier_type": {"type": "string"}
      },
      "additionalProperties": true
    },
    "disagreementRelation": {
      "type": "object",
      "required": ["relation_id", "claim_group_id", "relation_type", "claim_uids", "confidence", "human_review_required", "why_flagged"],
      "properties": {
        "relation_id": {"type": "string"},
        "claim_group_id": {"type": "string"},
        "relation_type": {"enum": ["support_vs_caution", "alternative_explanation", "numeric_mismatch", "framing_conflict", "unknown"]},
        "claim_uids": {"type": "array", "items": {"type": "string"}},
        "confidence": {"enum": ["high", "medium", "low"]},
        "human_review_required": {"type": "boolean"},
        "why_flagged": {"type": "string"}
      },
      "additionalProperties": true
    },
    "outlierDetail": {
      "type": "object",
      "required": ["claim_group_id", "outlier_type", "claim_uids", "followup_priority", "why_outlier"],
      "properties": {
        "claim_group_id": {"type": "string"},
        "outlier_type": {"enum": ["single_source_outlier", "low_source_diversity_outlier", "semantic_outlier", "high_stakes_single_source"]},
        "claim_uids": {"type": "array", "items": {"type": "string"}},
        "followup_priority": {"enum": ["low", "medium", "high"]},
        "why_outlier": {"type": "string"}
      },
      "additionalProperties": true
    },
    "claimIndexRecord": {
      "type": "object",
      "required": ["claim_uid", "source_video_id", "text", "speaker", "time_ref", "evidence_ids", "evidence_coordinate", "confidence", "modality_sources", "verification_status", "need_gates"],
      "properties": {
        "claim_uid": {"type": "string"},
        "source_video_id": {"type": "string"},
        "text": {"type": "string"},
        "speaker": {"type": ["string", "null"]},
        "time_ref": {"type": ["string", "null"]},
        "evidence_ids": {"type": "array", "items": {"type": "string"}},
        "evidence_coordinate": {"type": "object"},
        "confidence": {"type": "string"},
        "modality_sources": {"type": "array", "items": {"type": "string"}},
        "verification_status": {"const": "video_internal_not_fact_checked"},
        "need_gates": {"type": "object"}
      },
      "additionalProperties": true
    },
    "evidenceIndexRecord": {
      "type": "object",
      "required": ["evidence_id", "video_id", "timestamp_start", "timestamp_end", "time_ref", "speaker", "modality", "text", "confidence"],
      "properties": {
        "evidence_id": {"type": "string"},
        "video_id": {"type": "string"},
        "timestamp_start": {"type": ["number", "null"]},
        "timestamp_end": {"type": ["number", "null"]},
        "time_ref": {"type": ["string", "null"]},
        "speaker": {"type": ["string", "null"]},
        "modality": {"type": "array", "items": {"type": "string"}},
        "text": {"type": "string"},
        "confidence": {"type": "string"}
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
